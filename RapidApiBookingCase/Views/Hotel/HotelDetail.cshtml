@model RapidApiBookingCase.Models.HotelDetailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model?.HotelDetail?.Name | VETRA</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { fontFamily: { sans: ['Montserrat', 'sans-serif'], serif: ['"Playfair Display"', 'serif'] }, colors: { luxury: { bg: '#0A0A0B', card: '#141416', border: '#26262A', text: '#D4D4D6', muted: '#8A8A8F' }, gold: { DEFAULT: '#C5A880', hover: '#B0946E' } } } } }
    </script>
    <style>
        body {
            background-color: #0A0A0B;
            color: #D4D4D6;
        }</style>
</head>
<body class="font-sans antialiased pb-32">

    <div class="bg-luxury-bg/95 backdrop-blur border-b border-luxury-border sticky top-0 z-50">
        @await Component.InvokeAsync("_DefaultNavbarComponentPartial")
    </div>

    @if (Model != null && Model.HotelDetail != null && !string.IsNullOrEmpty(Model.HotelDetail.Name))
    {
        <div class="max-w-7xl mx-auto px-4 pt-12 pb-8">
            <div class="flex justify-between items-end gap-8">
                <div>
                    <h1 class="text-5xl font-serif text-white mb-4">@Model.HotelDetail.Name</h1>
                    <p class="flex items-center gap-2 text-luxury-muted text-sm"><i data-lucide="map-pin" class="w-4 h-4 text-gold"></i>@Model.HotelDetail.Address, @Model.HotelDetail.City</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.HotelDetail.ReviewScore) && Model.HotelDetail.ReviewScore != "N/A")
                {
                    <div class="flex items-center gap-4 border border-luxury-border p-4 bg-luxury-card rounded-lg">
                        <div class="text-right">
                            <div class="text-gold font-serif text-xl">@Model.HotelDetail.ReviewScoreWord</div>
                            <div class="text-[10px] text-luxury-muted uppercase tracking-widest">Rating</div>
                        </div>
                        <div class="w-14 h-14 border border-gold/40 rounded-full flex items-center justify-center font-serif text-2xl text-white bg-luxury-bg">@Model.HotelDetail.ReviewScore</div>
                    </div>
                }
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 mb-16">
            @if (Model.PhotoUrls != null && Model.PhotoUrls.Count > 0)
            {
                <div class="grid grid-cols-4 gap-4 h-[500px]">
                    <div class="col-span-3 h-full rounded-lg overflow-hidden bg-luxury-card border border-luxury-border">
                        <img src="@Model.PhotoUrls[0]" class="w-full h-full object-cover">
                    </div>
                    <div class="col-span-1 flex flex-col gap-4 h-full">
                        @foreach (var photoUrl in Model.PhotoUrls.Skip(1).Take(2))
                        {
                            <div class="flex-1 rounded-lg overflow-hidden bg-luxury-card border border-luxury-border"><img src="@photoUrl" class="w-full h-full object-cover"></div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
            <div class="lg:col-span-8">

                <section class="mb-12">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <p class="text-gold text-xs mb-3 uppercase tracking-widest font-medium">Description</p>
                            <h2 class="text-3xl font-serif text-white">About This Hotel</h2>
                        </div>
                        <div class="text-lg tracking-widest flex gap-1">
                            @{
                                int starCount = 5;
                                if (double.TryParse(Model.HotelDetail.ReviewScore, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double ds))
                                {
                                    starCount = (int)Math.Round(ds / 2);
                                    if (starCount < 1) starCount = 1;
                                    if (starCount > 5) starCount = 5;
                                }
                            }
                            @for (int s = 0; s < starCount; s++)
                            {
                                <span class="text-gold">★</span>
                            }
                            @for (int s = starCount; s < 5; s++)
                            {
                                <span class="text-luxury-border">★</span>
                            }
                        </div>
                    </div>
                    <div class="text-luxury-muted leading-relaxed font-light">
                        @Html.Raw(Model.HotelDetail.Description)
                    </div>
                </section>

                <div class="w-full h-px bg-luxury-border mb-12"></div>

                <section class="mb-12">
                    <p class="text-gold text-xs mb-3 uppercase tracking-widest font-medium">Amenities</p>
                    <h2 class="text-3xl font-serif text-white mb-6">Facilities & Services</h2>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                        @foreach (var facility in Model.Facilities)
                        {
                            <div class="flex items-center gap-3 bg-luxury-card border border-luxury-border p-4 rounded-lg">
                                <i data-lucide="check" class="w-4 h-4 text-gold"></i>
                                <span class="text-sm text-luxury-muted">@facility</span>
                            </div>
                        }
                    </div>
                </section>

                <div class="w-full h-px bg-luxury-border mb-12"></div>

                <section class="mb-12">
                    <p class="text-gold text-xs mb-3 uppercase tracking-widest font-medium">Accommodation</p>
                    <h2 class="text-3xl font-serif text-white mb-6">Choose Your Room</h2>
                    <div class="flex flex-col gap-4">
                        @foreach (var room in Model.Rooms)
                        {
                            <div class="flex flex-col md:flex-row justify-between items-center bg-luxury-card border border-luxury-border p-6 rounded-lg group hover:border-gold/40 transition">
                                <div class="flex-1">
                                    <h3 class="text-xl font-serif text-white mb-2">@room.Name</h3>
                                    <div class="flex items-center gap-4 text-xs text-luxury-muted mb-3">
                                        <span class="flex items-center gap-1"><i data-lucide="maximize" class="w-3 h-3 text-gold"></i> @room.Size</span>
                                        <span class="flex items-center gap-1"><i data-lucide="bed" class="w-3 h-3 text-gold"></i> @room.BedType</span>
                                    </div>
                                    <div class="text-xs @(room.Feature.Contains("cancellation") ? "text-teal-400" : "text-gold")">@room.Feature</div>
                                </div>
                                <div class="text-right mt-4 md:mt-0 border-t md:border-t-0 md:border-l border-luxury-border pt-4 md:pt-0 md:pl-6 w-full md:w-auto">
                                    <div class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1">Price</div>
                                    <div class="text-2xl font-serif text-white mb-3">@room.Price</div>
                                    <button class="bg-luxury-bg border border-gold text-gold hover:bg-gold hover:text-luxury-bg px-8 py-2.5 rounded text-xs font-semibold uppercase tracking-widest transition w-full">Select</button>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <div class="w-full h-px bg-luxury-border mb-12"></div>

                @if (Model.Reviews != null && Model.Reviews.Count > 0)
                {
                    <section class="mb-12">
                        <p class="text-gold text-xs mb-3 uppercase tracking-widest font-medium">Guest Experiences</p>
                        <h2 class="text-3xl font-serif text-white mb-6">Recent Reviews</h2>

                        <div class="flex flex-col gap-4 w-full">
                            @foreach (var review in Model.Reviews)
                            {
                                <div class="bg-luxury-card border border-luxury-border p-6 rounded-lg w-full">
                                    <div class="flex justify-between items-start mb-5 pb-4 border-b border-luxury-border/50">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 rounded-full bg-luxury-bg border border-gold/30 flex items-center justify-center text-gold font-serif text-lg">
                                                @review.AuthorName.Substring(0, 1).ToUpper()
                                            </div>
                                            <div>
                                                <div class="text-white font-serif font-medium">@review.AuthorName</div>
                                                <div class="text-xs text-luxury-muted mt-0.5">@review.Date</div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-1.5 bg-luxury-bg px-3 py-1.5 rounded border border-white/5">
                                            <span class="text-gold text-sm font-bold">@review.Score.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(review.Pros))
                                    {
                                        <div class="text-luxury-muted text-sm mb-3 flex items-start gap-2">
                                            <i data-lucide="plus" class="w-4 h-4 text-gold flex-shrink-0 mt-0.5"></i>
                                            <span class="leading-relaxed">@Html.Raw(review.Pros)</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(review.Cons))
                                    {
                                        <div class="text-luxury-muted text-sm flex items-start gap-2">
                                            <i data-lucide="minus" class="w-4 h-4 text-red-400 flex-shrink-0 mt-0.5"></i>
                                            <span class="leading-relaxed">@Html.Raw(review.Cons)</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </section>
                    <div class="w-full h-px bg-luxury-border mb-12"></div>
                }

                <section class="mb-12">
                    <p class="text-gold text-xs mb-3 uppercase tracking-widest font-medium">Location</p>
                    <h2 class="text-3xl font-serif text-white mb-6">Explore the Neighborhood</h2>
                    @if (Model.HotelDetail.Latitude.HasValue && Model.HotelDetail.Longitude.HasValue)
                    {
                        var lat = Model.HotelDetail.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var lon = Model.HotelDetail.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);

                        <div class="w-full h-[400px] rounded-lg overflow-hidden border border-luxury-border">
                            <iframe width="100%" height="100%" frameborder="0" style="border:0"
                                    src="https://maps.google.com/maps?q=@(lat),@(lon)&z=15&output=embed"
                                    allowfullscreen>
                            </iframe>
                        </div>
                    }
                </section>
            </div>

            <div class="lg:col-span-4 self-start sticky top-32 bg-luxury-card border border-luxury-border p-8 shadow-2xl rounded-lg">
                <p class="text-[10px] uppercase text-luxury-muted mb-6 tracking-widest">Reservation Details</p>
                <div class="space-y-4 mb-8">
                    <div class="flex justify-between items-center border border-luxury-border p-4 bg-luxury-bg rounded">
                        <div><div class="text-[10px] text-gold uppercase mb-1 tracking-widest">Check-In</div><div class="text-white font-serif text-lg">@Model.CheckIn</div></div>
                        <div class="text-xs text-luxury-muted">@Model.CheckInTime</div>
                    </div>
                    <div class="flex justify-between items-center border border-luxury-border p-4 bg-luxury-bg rounded">
                        <div><div class="text-[10px] text-gold uppercase mb-1 tracking-widest">Check-Out</div><div class="text-white font-serif text-lg">@Model.CheckOut</div></div>
                        <div class="text-xs text-luxury-muted">@Model.CheckOutTime</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.HotelDetail.Url))
                {
                    <a href="@Model.HotelDetail.Url" target="_blank" class="block w-full bg-gold hover:bg-gold-hover text-luxury-bg font-bold uppercase tracking-widest transition-colors duration-300 text-xs py-5 rounded text-center">
                        Book on Booking.com
                    </a>
                }
            </div>
        </div>
    }
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>lucide.createIcons();</script>
</body>
</html>