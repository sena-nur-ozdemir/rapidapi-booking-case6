@model List<RapidApiBookingCase.Models.HotelListViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VETRA | @ViewBag.CityName Hotels</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { fontFamily: { sans: ['Montserrat', 'sans-serif'], serif: ['"Playfair Display"', 'serif'] }, colors: { luxury: { bg: '#0A0A0B', card: '#141416', border: '#26262A', text: '#D4D4D6', muted: '#8A8A8F' }, gold: { DEFAULT: '#C5A880', hover: '#B0946E' } } } } }
    </script>
    <style>
        body {
            background-color: #0A0A0B;
            color: #D4D4D6;
        }
    </style>
</head>
<body class="font-sans antialiased bg-luxury-bg relative">

    <div class="bg-luxury-bg/95 backdrop-blur border-b border-luxury-border">
        @await Component.InvokeAsync("_DefaultNavbarComponentPartial")
    </div>

    <main class="max-w-7xl mx-auto px-4 pt-12 pb-24 relative z-10">

        <div class="bg-luxury-card border border-luxury-border rounded-lg p-5 mb-10 shadow-xl">
            <form method="get" action="/Hotel/HotelList" class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-[2] w-full">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1.5 block">Destination</label>
                    <input type="text" name="cityName" value="@ViewBag.CityName" required class="w-full bg-luxury-bg border border-luxury-border text-white px-4 py-3 focus:border-gold outline-none transition font-serif rounded-sm">
                </div>
                <div class="flex-1 w-full">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1.5 block">Check-in</label>
                    <input type="date" name="checkIn" value="@ViewBag.CheckIn" required class="w-full bg-luxury-bg border border-luxury-border text-white px-4 py-3 focus:border-gold outline-none transition font-serif rounded-sm">
                </div>
                <div class="flex-1 w-full">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1.5 block">Check-out</label>
                    <input type="date" name="checkOut" value="@ViewBag.CheckOut" required class="w-full bg-luxury-bg border border-luxury-border text-white px-4 py-3 focus:border-gold outline-none transition font-serif rounded-sm">
                </div>
                <div class="flex-[0.5] w-full">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1.5 block">Guests</label>
                    <input type="number" name="adults" value="@(ViewBag.Adults ?? 2)" min="1" max="10" required class="w-full bg-luxury-bg border border-luxury-border text-white px-4 py-3 focus:border-gold outline-none transition font-serif text-center rounded-sm">
                </div>
                <div class="w-full md:w-auto">
                    <button type="submit" class="w-full bg-gold hover:bg-gold-hover text-luxury-bg font-semibold uppercase tracking-widest text-xs px-8 py-3.5 rounded-sm transition duration-300">
                        Explore
                    </button>
                </div>
            </form>
        </div>

        @if (Model != null && Model.Count > 0)
        {
            <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-8 border-b border-luxury-border pb-4 gap-4">
                <div>
                    <h1 class="text-3xl font-serif text-white">Curated Stays in <span class="italic text-gold">@ViewBag.CityName</span></h1>
                </div>
                <p class="text-luxury-muted text-xs tracking-widest uppercase">
                    Showing @Model.Count() properties
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var hotel in Model)
                {
                    <article class="bg-luxury-card border border-luxury-border rounded-lg overflow-hidden group flex flex-col h-full hover:border-gold/40 transition-colors duration-300">
                        <div class="relative h-52 overflow-hidden bg-luxury-bg shrink-0">
                            <img src="@hotel.ImageUrl" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-90 group-hover:opacity-100">
                            @if (hotel.Score != null)
                            {
                                <div class="absolute top-3 right-3 bg-luxury-bg/95 backdrop-blur px-2.5 py-1 border border-white/10 rounded flex items-center gap-1.5 shadow-lg">
                                    <span class="text-gold text-[10px]">★</span>
                                    <span class="text-white text-xs font-bold font-serif tracking-wide">@hotel.Score</span>
                                </div>
                            }
                        </div>

                        <div class="p-5 flex flex-col flex-grow">
                            <h3 class="text-lg font-serif text-white leading-snug mb-1.5 line-clamp-2" title="@hotel.Name">@hotel.Name</h3>

                            <div class="flex items-center gap-1 text-xs mb-3 tracking-widest">
                                @{
                                    int starCount = 5; 
                                    if (hotel.Score.HasValue)
                                    {
                                        starCount = (int)Math.Round(hotel.Score.Value / 2.0);
                                        if (starCount < 1) starCount = 1;
                                        if (starCount > 5) starCount = 5;
                                    }
                                }
                                @for (int s = 0; s < starCount; s++)
                                {
                                    <span class="text-gold">★</span>
                                }
                                @for (int s = starCount; s < 5; s++)
                                {
                                    <span class="text-luxury-border">★</span>
                                }
                            </div>

                            <div class="space-y-2 mb-5 flex-grow">
                                <p class="text-luxury-muted text-xs tracking-wide flex items-center gap-2">
                                    <i data-lucide="map-pin" class="w-3.5 h-3.5 text-gold/70"></i> @hotel.Distance
                                </p>
                                @if (!string.IsNullOrEmpty(hotel.ScoreWord))
                                {
                                    <p class="text-luxury-muted text-xs tracking-wide flex items-center gap-2">
                                        <i data-lucide="award" class="w-3.5 h-3.5 text-gold/70"></i> <span class="text-white/90">@hotel.ScoreWord</span>
                                    </p>
                                }
                            </div>

                            <div class="border-t border-luxury-border/60 pt-4 mt-auto flex items-end justify-between">
                                <div>
                                    <span class="text-[9px] uppercase tracking-widest text-luxury-muted block mb-0.5">Price Per Night</span>
                                    <span class="text-xl font-serif text-gold font-semibold">@(string.IsNullOrEmpty(hotel.PriceRounded) ? "N/A" : hotel.PriceRounded)</span>
                                </div>
                                <a href="/Hotel/HotelDetail?hotelId=@hotel.HotelId&checkIn=@ViewBag.CheckIn&checkOut=@ViewBag.CheckOut" class="bg-luxury-bg border border-luxury-border hover:border-gold text-white hover:text-gold text-[10px] uppercase tracking-widest px-4 py-2.5 rounded transition-all flex items-center gap-1.5">
                                    Details <i data-lucide="chevron-right" class="w-3 h-3"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="text-center py-20 border border-luxury-border rounded-lg bg-luxury-card mt-12">
                <i data-lucide="alert-circle" class="w-12 h-12 text-gold mx-auto mb-4"></i>
                <h3 class="text-xl font-serif text-white mb-2">No Properties Found</h3>
                <p class="text-luxury-muted mb-2">@ViewBag.ErrorMessage</p>
                <a href="/Hotel/Index" class="inline-block mt-6 border border-gold/30 hover:border-gold text-gold px-6 py-2.5 transition text-xs tracking-widest uppercase">Return to Search</a>
            </div>
        }
    </main>

    @await Component.InvokeAsync("_DefaultFooterComponentPartial")

    <script src="https://unpkg.com/lucide@latest"></script>
    <script> lucide.createIcons(); </script>
</body>
</html>