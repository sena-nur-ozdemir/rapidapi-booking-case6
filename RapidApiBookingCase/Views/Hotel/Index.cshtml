@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VETRA | Curated Luxury Stays</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { fontFamily: { sans: ['Montserrat', 'sans-serif'], serif: ['"Playfair Display"', 'serif'] }, colors: { luxury: { bg: '#0A0A0B', card: '#141416', border: '#26262A', text: '#D4D4D6', muted: '#8A8A8F' }, gold: { DEFAULT: '#C5A880', hover: '#B0946E' } } } } }
    </script>
    <style>
        body {
            background-color: #0A0A0B;
            color: #D4D4D6;
        }

        ::-webkit-calendar-picker-indicator {
            filter: invert(1);
            cursor: pointer;
            opacity: 0.6;
            transition: 0.3s;
        }

            ::-webkit-calendar-picker-indicator:hover {
                opacity: 1;
            }
    </style>
</head>
<body class="font-sans antialiased flex items-center justify-center min-h-screen relative overflow-hidden">

    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=2000&q=80" alt="Vetra Background" class="w-full h-full object-cover opacity-30" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0B] via-[#0A0A0B]/80 to-transparent"></div>
    </div>

    <div class="w-full max-w-5xl px-4 relative z-10">
        <div class="text-center mb-12">
            <h1 class="text-5xl md:text-7xl font-serif text-white mb-4 tracking-wider">VETRA</h1>
            <p class="text-gold tracking-[0.3em] text-xs uppercase">Curated Luxury Stays</p>
        </div>

        <div class="bg-luxury-card/90 backdrop-blur-md border border-luxury-border p-6 rounded-lg shadow-2xl">
            <form method="post" action="/Hotel/Index" class="flex flex-col md:flex-row gap-4">

                <div class="flex-[2]">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1 block font-semibold">Destination</label>
                    <input type="text" name="cityName" placeholder="e.g. Lucerne, Paris..." required
                           class="w-full bg-transparent border-b border-luxury-border text-white px-2 py-3 focus:outline-none focus:border-gold transition text-lg font-serif placeholder-luxury-muted/50">
                </div>

                <div class="flex-1">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1 block font-semibold">Check-in</label>
                    <input type="date" name="checkIn" required
                           class="w-full bg-transparent border-b border-luxury-border text-white/80 px-2 py-3 focus:outline-none focus:border-gold transition text-lg font-serif">
                </div>

                <div class="flex-1">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1 block font-semibold">Check-out</label>
                    <input type="date" name="checkOut" required
                           class="w-full bg-transparent border-b border-luxury-border text-white/80 px-2 py-3 focus:outline-none focus:border-gold transition text-lg font-serif">
                </div>

                <div class="flex-[0.5]">
                    <label class="text-[10px] text-luxury-muted uppercase tracking-widest mb-1 block font-semibold">Guests</label>
                    <input type="number" name="adults" value="2" min="1" max="10" required
                           class="w-full bg-transparent border-b border-luxury-border text-white px-2 py-3 focus:outline-none focus:border-gold transition text-lg font-serif text-center">
                </div>

                <div class="w-full md:w-auto flex items-end">
                    <button type="submit" class="w-full md:w-auto bg-gold hover:bg-gold-hover text-luxury-bg font-semibold uppercase tracking-widest text-xs px-10 py-4 rounded transition duration-300">
                        Explore
                    </button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>