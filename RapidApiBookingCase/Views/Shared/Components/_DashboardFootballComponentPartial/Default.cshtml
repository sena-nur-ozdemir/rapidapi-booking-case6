@model List<RapidApiBookingCase.Dtos.DashboardDtos.Match>
<div class="bg-luxury-card border border-luxury-border rounded-xl p-6 h-full">
    <div class="flex justify-between items-center mb-6">
        <h3 class="text-white font-serif text-lg flex items-center gap-2"><i data-lucide="activity" class="w-5 h-5 text-gold"></i> Recent Sports</h3>
    </div>
    <div class="space-y-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model.Take(3))
            {
                <div class="bg-luxury-bg border border-luxury-border p-4 rounded-lg flex flex-col items-center">
                    <div class="flex justify-between items-center w-full text-white text-sm font-serif mb-3">
                        <span class="w-[40%] truncate font-medium text-right pr-3">@(item.home?.name ?? "-")</span>
                        <span class="bg-luxury-card border border-luxury-border/50 text-gold px-3 py-1 rounded font-bold text-center">@(item.home?.score ?? 0) - @(item.away?.score ?? 0)</span>
                        <span class="w-[40%] truncate font-medium text-left pl-3">@(item.away?.name ?? "-")</span>
                    </div>
                    <div class="text-[9px] text-luxury-muted uppercase tracking-widest bg-[#1a1a1f] px-3 py-1 rounded-full">
                        <i data-lucide="check-circle" class="w-3 h-3 inline-block mr-1 text-luxury-muted"></i> FINISHED
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-luxury-muted text-xs text-center py-4">No recent matches.</div>
        }
    </div>
</div>