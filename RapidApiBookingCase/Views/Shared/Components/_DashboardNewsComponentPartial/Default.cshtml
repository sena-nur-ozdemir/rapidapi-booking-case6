@model List<RapidApiBookingCase.Dtos.DashboardDtos.NewsData>
<div class="bg-luxury-card border border-luxury-border rounded-xl p-6 h-full flex flex-col">
    <h3 class="text-white font-serif text-2xl flex items-center gap-2 mb-6"><i data-lucide="globe" class="w-6 h-6 text-gold"></i> Global Insights</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 flex-grow">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model.Take(2))
            {
                <a href="@item.link" target="_blank" class="group block h-full flex flex-col">
                    <div class="h-40 bg-luxury-bg border border-luxury-border rounded mb-4 overflow-hidden shrink-0">
                        <img src="@item.photo_url" class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition duration-700">
                    </div>
                    <p class="text-gold text-[10px] uppercase tracking-widest mb-2 truncate">@item.source_name</p>
                    <h4 class="text-white text-base font-serif line-clamp-2 leading-snug group-hover:text-gold transition-colors">@item.title</h4>
                </a>
            }
        }
        else
        {
            <div class="group cursor-pointer flex flex-col">
                <div class="h-40 bg-luxury-bg border border-luxury-border rounded mb-4 overflow-hidden shrink-0">
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600" class="w-full h-full object-cover opacity-60">
                </div>
                <p class="text-gold text-[10px] uppercase tracking-widest mb-2">Travel</p>
                <h4 class="text-white text-base font-serif">Vetra announces new exclusive sanctuary.</h4>
            </div>
            <div class="group cursor-pointer flex flex-col">
                <div class="h-40 bg-luxury-bg border border-luxury-border rounded mb-4 overflow-hidden shrink-0">
                    <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=600" class="w-full h-full object-cover opacity-60">
                </div>
                <p class="text-gold text-[10px] uppercase tracking-widest mb-2">Business</p>
                <h4 class="text-white text-base font-serif">Hospitality sector sees massive growth.</h4>
            </div>
        }
    </div>
</div>